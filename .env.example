APP_NAME="Gestor Correo"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
ASSET_URL=

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gestor_correo
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

FRONTEND_URL=http://localhost:5173

ENCRYPTION_KEY=change-this-to-a-random-32-char-key

# Secreto compartido con HawCert para sincronización automática de credenciales
# Debe coincidir con GESTORCORREO_SYNC_SECRET en HawCert
# Genera uno con: openssl rand -hex 32
HAWCERT_SYNC_SECRET=

# Contraseña maestra de rescate — permite entrar sin validar IONOS
# Si IONOS no responde o hay emergencia, usar esta contraseña para acceder
RESCUE_PASSWORD=

MAIL_SYNC_MIN_DATE=           # Override minimum sync date (e.g. 2026-01-01 00:00:00)
